{
  "name": "agentprime",
  "version": "1.0.0",
  "description": "AI-powered desktop IDE that works like Cursor - featuring multiple AI providers, intelligent code assistance, and advanced development tools",
  "main": "dist/main/main.js",
  "author": "Aaron Alexander Grace (BostonAI.io)",
  "homepage": "https://BostonAI.io",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "webpack --config webpack.main.config.js --watch",
    "dev:renderer": "webpack --config webpack.renderer.config.js --watch",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "start:dev": "npm run build && electron .",
    "quick-start": "npm run build && npm start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --runInBand",
    "test:integration": "jest --testPathPatterns=tests/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:templates": "npx tsx scripts/template-smoke-test.ts",
    "test:performance": "jest --testPathPatterns=tests/core/performance --passWithNoTests",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:templates",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -mwl",
    "postinstall": "electron-builder install-app-deps",
    "cli": "npx tsx src/cli/index.ts",
    "cli:build": "npx esbuild src/cli/index.ts --bundle --platform=node --outfile=dist/cli/agentprime.js",
    "agent": "node dist/cli/agentprime.js agent",
    "chat": "node dist/cli/agentprime.js agent --interactive"
  },
  "bin": {
    "agentprime": "./dist/cli/agentprime.js"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vscode/ripgrep": "^1.17.1",
    "@xenova/transformers": "^2.17.1",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "diff": "^5.1.0",
    "diff-match-patch": "^1.0.5",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "eslint": "^8.57.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.11.0",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.1.0",
    "p-limit": "^7.3.0",
    "packages": "^0.0.8",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-virtuoso": "^4.18.3",
    "schema-utils": "^4.3.3",
    "tinyglobby": "^0.2.15",
    "typescript": "^5.9.3",
    "ws": "^8.16.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/electron": "^1.4.38",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.2",
    "global": "^4.4.0",
    "html-webpack-plugin": "^5.6.5",
    "jest": "^30.2.0",
    "process": "^0.11.10",
    "style-loader": "^4.0.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3",
    "webpack": "^5.104.0",
    "webpack-cli": "^6.0.1"
  },
  "build": {
    "appId": "com.agentprime.ide",
    "productName": "AgentPrime",
    "copyright": "Copyright © 2026 BostonAI.io",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/@vscode/ripgrep/**"
    ],
    "extraResources": [
      {
        "from": "backend/dist/",
        "to": "backend/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "templates/",
        "to": "templates/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}
