# AgentPrime AI Configuration
# Copy this to .env and customize

# ════════════════════════════════════════════════════════════════
# OLLAMA CLOUD (Recommended - no local install needed!)
# ════════════════════════════════════════════════════════════════
# Get your API key from: https://ollama.com (sign in first)
# Official endpoint: https://ollama.com/api
OLLAMA_URL=https://ollama.com/api
OLLAMA_MODEL=kimi-k2.6:cloud
OLLAMA_API_KEY=your-ollama-cloud-api-key-here
OLLAMA_FAST_MODEL=deepseek-v4-flash:cloud

# Secondary model (fallback)
OLLAMA_URL_SECONDARY=https://ollama.com/api
OLLAMA_MODEL_FALLBACK=qwen3-coder-next:cloud
OLLAMA_API_KEY_DESKTOP=

# ════════════════════════════════════════════════════════════════
# LOCAL OLLAMA (Alternative - requires ollama installed locally)
# ════════════════════════════════════════════════════════════════
# Uncomment these and comment out the cloud config above to use local:
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_API_KEY=
# OLLAMA_URL_SECONDARY=http://127.0.0.1:11435
# OLLAMA_MODEL_FALLBACK=deepseek-coder:6.7b

# ════════════════════════════════════════════════════════════════
# OTHER PROVIDERS (optional)
# ════════════════════════════════════════════════════════════════
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ════════════════════════════════════════════════════════════════
# OPTIONAL RUNTIME FLAGS
# ════════════════════════════════════════════════════════════════
# Python Brain is enabled by default. Set to false to run desktop-only.
AGENTPRIME_ENABLE_BRAIN=true
# Base URL used by Electron when calling Python Brain IPC bridge.
BRAIN_URL=http://127.0.0.1:8000

# Backend model endpoint compatibility:
# - Desktop app uses OLLAMA_URL
# - Backend also accepts OLLAMA_BASE_URL
# If you run backend manually, set one of these if needed.
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional manual backend binding overrides
# AGENTPRIME_BACKEND_HOST=127.0.0.1
# AGENTPRIME_BACKEND_PORT=8000
